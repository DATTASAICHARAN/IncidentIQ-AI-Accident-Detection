rules_version = '2';
// Deploy: Firebase Console → Firestore → Rules, or `firebase deploy --only firestore:rules`
// Authenticated users may create their own SOS rows; blood/location stay write-only from clients as designed.

service cloud.firestore {
  match /databases/{database}/documents {
    match /emergency_alerts/{alertId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.keys().hasAll(['userId', 'latitude', 'longitude', 'bloodGroup', 'timestamp'])
        && request.resource.data.bloodGroup is string
        && request.resource.data.latitude is number
        && request.resource.data.longitude is number;
      allow read, update, delete: if false;
    }
  }
}
